-- LÓGICA: DYNAMIC FLING (PREDIÇÃO APENAS EM MOVIMENTO) 🌪️
-----------------------------------------------------------
local flingActive = false
local predictMult = 0.22 -- O quanto ele vai "cortar a frente"

FlingOthersBtn.MouseButton1Click:Connect(function()
    flingActive = not flingActive
    FlingOthersBtn.Text = flingActive and "Dynamic Fling: ON" or "Dynamic Fling: OFF"
    FlingOthersBtn.BackgroundColor3 = flingActive and Color3.fromRGB(255, 50, 50) or Color3.fromRGB(120, 20, 20)

    if flingActive then
        task.spawn(function()
            local hrp = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
            if not hrp then return end

            local velocity = Instance.new("BodyVelocity", hrp)
            velocity.Velocity = Vector3.new(0, 0, 0)
            velocity.MaxForce = Vector3.new(math.huge, math.huge, math.huge)

            local rot = Instance.new("BodyAngularVelocity", hrp)
            rot.AngularVelocity = Vector3.new(0, 999999, 0)
            rot.MaxTorque = Vector3.new(0, math.huge, 0)

            while flingActive do
                for _, player in pairs(Players:GetPlayers()) do
                    if player ~= LocalPlayer and player.Character and player.Character:FindFirstChild("HumanoidRootPart") then
                        if not flingActive then break end
                        
                        local targetHRP = player.Character.HumanoidRootPart
                        
                        repeat
                            if not flingActive or not targetHRP or not targetHRP.Parent then break end
                            
                            -- Detecta se o player está parado ou andando
                            local isMoving = targetHRP.Velocity.Magnitude > 2
                            local finalPos
                            
                            if isMoving then
                                -- Se estiver andando, joga a posição pra frente (Velocity * Mult)
                                finalPos = targetHRP.CFrame + (targetHRP.Velocity * predictMult)
                            else
                                -- Se estiver parado, fica exatamente no centro dele
                                finalPos = targetHRP.CFrame
                            end
                            
                            -- Aplica o teleporte com rotação doida pra flingar
                            hrp.CFrame = finalPos * CFrame.Angles(math.rad(math.random(0,360)), math.rad(math.random(0,360)), 0)
                            
                            task.wait()
                        until (targetHRP.Position - hrp.Position).Magnitude > 60
                        
                        task.wait(0.05)
                    end
                end
                task.wait()
            end

            velocity:Destroy()
            rot:Destroy()
        end)
    end
end)

