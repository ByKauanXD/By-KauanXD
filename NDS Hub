local function createSlider(name, min, max, default)
    local cont = Instance.new("Frame", ScrollFrame)
    cont.Size = UDim2.new(0.9, 0, 0, 70)
    cont.BackgroundTransparency = 1
    local lbl = Instance.new("TextLabel", cont); lbl.Size = UDim2.new(1, 0, 0, 30); lbl.Text = name .. ": " .. default; lbl.TextColor3 = Color3.new(1, 1, 1); lbl.Font = Enum.Font.GothamBold; lbl.TextSize = 18; lbl.BackgroundTransparency = 1
    local back = Instance.new("Frame", cont); back.Size = UDim2.new(0.9, 0, 0, 10); back.Position = UDim2.new(0.05, 0, 0, 45); back.BackgroundColor3 = Color3.fromRGB(50, 50, 60); Instance.new("UICorner", back)
    local main = Instance.new("TextButton", back); main.Size = UDim2.new(0, 26, 0, 26); main.Position = UDim2.new((default-min)/(max-min), -13, 0.5, -13); main.BackgroundColor3 = Color3.fromRGB(100, 100, 255); main.Text = ""; Instance.new("UICorner", main).CornerRadius = UDim.new(1, 0)
