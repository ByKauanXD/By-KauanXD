-- Anti-Fling
local isAntiFling = false
AntiFlingBtn.MouseButton1Click:Connect(function()
    if not isAntiFling then
        isAntiFling = true
        AntiFlingBtn.Text = "AntiFling ATIVADO"
        AntiFlingBtn.BackgroundColor3 = Color3.fromRGB(30, 80, 50)
        local function fix(c)
            for _, v in pairs(c:GetDescendants()) do if v:IsA("BasePart") then v.CanCollide = false end end
            c.DescendantAdded:Connect(function(v) if v:IsA("BasePart") then v.CanCollide = false end end)
        end
        LocalPlayer.CharacterAdded:Connect(fix)
        if LocalPlayer.Character then fix(LocalPlayer.Character) end
        for _, p in pairs(Players:GetPlayers()) do if p ~= LocalPlayer then p.CharacterAdded:Connect(fix); if p.Character then fix(p.Character) end end end
    end
end)

